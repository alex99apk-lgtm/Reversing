local a = getgenv()

-- 1. Restaurar las funciones C originales desde el respaldo
if restorefunction then
    if a.OriginalLoadstring then 
        pcall(restorefunction, a.OriginalLoadstring) 
    end
    if a.OriginalRequest then 
        pcall(restorefunction, a.OriginalRequest) 
    end
end

-- 2. Devolver las variables globales a su estado natural
if a.OriginalLoadstring then
    a.loadstring = a.OriginalLoadstring
    loadstring = a.OriginalLoadstring
end

if a.OriginalRequest then
    a.request = a.OriginalRequest
    a.http_request = a.OriginalRequest
    if a.syn then 
        a.syn.request = a.OriginalRequest 
    end
end

-- 3. Limpiar la UI oculta
local uiName = "LoaderAnti"
local targetParent = pcall(function() return game:GetService("CoreGui") end) and game:GetService("CoreGui") or game:GetService("Players").LocalPlayer:FindFirstChild("PlayerGui")

if targetParent and targetParent:FindFirstChild(uiName) then
    targetParent[uiName]:Destroy()
end
